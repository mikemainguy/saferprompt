{
  "name": "saferprompt",
  "version": "0.0.8",
  "description": "Detect prompt injection attacks using the qualifire/prompt-injection-sentinel model",
  "type": "module",
  "main": "index.js",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "default": "./index.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/mikemainguy/saferprompt"
  },
  "homepage": "https://github.com/mikemainguy/saferprompt#readme",
  "bugs": {
    "url": "https://github.com/mikemainguy/saferprompt/issues"
  },
  "contributors": [
    {
      "name": "Michael Mainguy",
      "email": "mike.mainguy@gmail.com"
    }
  ],
  "scripts": {
    "start": "node server.js",
    "download-model": "node download-model.js",
    "test": "node --test",
    "test:coverage": "node --test --experimental-test-coverage",
    "docker:build": "docker build --no-cache -t michaelmainguy/saferprompt:latest -t michaelmainguy/saferprompt:$(node -p \"require('./package.json').version\") .",
    "docker:publish": "docker buildx build --platform linux/amd64,linux/arm64 --no-cache -t michaelmainguy/saferprompt:latest -t michaelmainguy/saferprompt:$(node -p \"require('./package.json').version\") --push .",
    "npm:publish": "npm publish"
  },
  "keywords": [
    "prompt-injection",
    "ai",
    "agentic",
    "llm",
    "security",
    "jailbreak",
    "transformers",
    "detection",
    "library",
    "api",
    "fastify",
    "http2",
    "prompt",
    "chatgpt",
    "anthropic",
    "claude"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@fastify/swagger": "^9.7.0",
    "@huggingface/transformers": "^3.8.1",
    "dotenv": "^17.3.1",
    "fastify": "^5.8.2",
    "marked": "^17.0.4"
  }
}
